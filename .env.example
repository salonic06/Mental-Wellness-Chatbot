# Meta WhatsApp Cloud API (required for app.py)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=wellness-bot-dev-123
META_APP_SECRET=

# App settings (optional)
TIMEZONE=Asia/Kolkata
ADMIN_NUMBERS=

# LLM brain (optional). Leave LLM_PROVIDER unset/none to keep the original
# rule-based replies. When enabled, /vent, /affirmation and /summary become
# personalized; any failure falls back to the deterministic responses.
#   LLM_PROVIDER: gemini | openai | openrouter | none
LLM_PROVIDER=none
LLM_API_KEY=
# Optional model override (defaults per provider):
#   gemini -> gemini-flash-lite-latest (generous FREE tier; good quality)
#   For paid/production, higher quality: LLM_MODEL=gemini-flash-latest
#   openai -> gpt-4o-mini | openrouter -> google/gemini-2.5-flash
LLM_MODEL=gemini-flash-lite-latest
LLM_TIMEOUT_SECONDS=30
LLM_MAX_ATTEMPTS=2
LLM_MAX_TOKENS=320
# Gemini only: 0 disables slow "thinking" tokens (best for short chat replies).
# Set to 'dynamic' to let the model decide.
LLM_THINKING_BUDGET=0

# Dashboard API (Phase C — set on Render when using Vercel dashboard)
DASHBOARD_API_KEY=
# Comma-separated Vercel URL(s), or * for dev only
DASHBOARD_CORS_ORIGINS=*

# wa.me invite link (/invite admin) — business display number, digits only, no +
WHATSAPP_DISPLAY_NUMBER=

# Timed meditation WhatsApp nudges (Render / always-on server)
ENABLE_MEDITATION_NUDGES=true

# Daily "time for check-in?" push (users opt in with /remind on)
ENABLE_DAILY_CHECKIN_NUDGES=false
DAILY_NUDGE_HOUR=9
DAILY_NUDGE_WINDOW_MINUTES=30
DAILY_NUDGE_POLL_SECONDS=900
